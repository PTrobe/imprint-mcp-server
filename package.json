{
  "name": "imprint-mcp-server",
  "version": "0.1.1",
  "description": "MCP server exposing Imprint's local data (meeting notes, calendar, emails) to Claude.",
  "license": "MIT",
  "homepage": "https://github.com/PTrobe/imprint-mcp-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PTrobe/imprint-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/PTrobe/imprint-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "claude",
    "imprint",
    "model-context-protocol",
    "sqlite",
    "productivity"
  ],
  "type": "module",
  "bin": {
    "imprint-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-sqlite3": "^11.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
